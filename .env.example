# =============================================================================
# Eternal Longevity — env vars
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`.
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Used by sitemap, robots, OG image, and absolute-URL generation.
# In production set this to https://eternallongevity.com
NEXT_PUBLIC_SITE_URL=https://eternallongevity.com


# -----------------------------------------------------------------------------
# Supabase  (Phase 2 — when real backend lands)
# -----------------------------------------------------------------------------
# Project URL + anon key are safe to expose; the service-role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# Stripe  (Phase 2 — real payments)
# -----------------------------------------------------------------------------
# Get these from dashboard.stripe.com → Developers → API keys.
# Use test keys (pk_test_…/sk_test_…) until launch, then swap to live.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Postmark — transactional email  (Phase 2)
# -----------------------------------------------------------------------------
# Used for: intake confirmation, physician sign-off, shipment updates.
# Postmark offers BAA on paid plans, which is required for PHI.
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=hello@eternallongevity.com


# -----------------------------------------------------------------------------
# Twilio — SMS  (Phase 3, optional)
# -----------------------------------------------------------------------------
# For SMS notifications (delivery alerts, security codes). Requires Twilio BAA
# if SMS will contain PHI.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=


# -----------------------------------------------------------------------------
# Sentry — error monitoring  (Phase 3)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=


# -----------------------------------------------------------------------------
# Analytics  (Phase 4)
# -----------------------------------------------------------------------------
# Posthog or Plausible. Choose one.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
