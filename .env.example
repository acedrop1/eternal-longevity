# =============================================================================
# Eternal Longevity — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit
# `.env.local`. In production, set the same keys in the Vercel dashboard
# (Project -> Settings -> Environment Variables).
#
# The app runs as a fully working localStorage-backed DEMO with none of these
# set. Each service switches on the moment its keys are present.
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Used by sitemap, robots, OG image, and absolute-URL generation.
NEXT_PUBLIC_SITE_URL=https://eternal-longevity-seven.vercel.app


# -----------------------------------------------------------------------------
# Supabase  — database + auth + storage
# -----------------------------------------------------------------------------
# From the Supabase dashboard -> Project Settings -> API.
# URL + anon key are public (safe in the browser). The service-role key is
# SERVER-ONLY — it bypasses Row-Level Security. Never expose it to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# Stripe  — payments + subscriptions
# -----------------------------------------------------------------------------
# From dashboard.stripe.com -> Developers -> API keys.
# Use test keys (pk_test_... / sk_test_...) until launch, then swap to live.
# The publishable key is prefixed NEXT_PUBLIC_ because Stripe.js needs it.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...). For local dev, `stripe listen` prints one.
# For production, copy it from the webhook endpoint you create in the dashboard.
STRIPE_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Resend  — transactional email
# -----------------------------------------------------------------------------
# From resend.com -> API Keys. Used for: intake confirmation, physician
# sign-off, shipment updates. Sign a BAA with Resend before sending PHI.
RESEND_API_KEY=
# Verified sender. Format: "Display Name <address@yourdomain.com>".
RESEND_FROM_EMAIL=Eternal Longevity <hello@eternallongevity.com>
# Inbox that receives "new intake to review" notifications.
CARE_TEAM_EMAIL=


# -----------------------------------------------------------------------------
# Twilio  — SMS  (optional)
# -----------------------------------------------------------------------------
# From console.twilio.com. Used for delivery alerts and 2FA codes. A Twilio BAA
# is required only if SMS will contain health information.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=


# -----------------------------------------------------------------------------
# Sentry — error monitoring  (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=


# -----------------------------------------------------------------------------
# Analytics  (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
